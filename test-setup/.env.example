# =============================================================
# LLM Provider Configuration
# Copy this file to .env and fill in your values:
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env
# =============================================================

# Which provider to use: openai | gemini | claude | azure
LLM_PROVIDER=azure

# --- Azure-OpenAI-style gateway (no personal API key needed) ---
# Use this when you only have access to a corporate gateway.
# The endpoint becomes:
#   {AZURE_API_BASE}/openai/deployments/{deployment}/chat/completions?api-version={AZURE_API_VERSION}
AZURE_API_BASE=https://<your-gateway-host>/<path>
AZURE_API_VERSION=2024-02-01
# Deployment names — change these freely as available models change.
AZURE_DEPLOYMENT_DEFAULT=gpt-4o
AZURE_DEPLOYMENT_MINI=gpt-4o-mini
# Bearer token sent as the "Authorization: Bearer <token>" header.
AZURE_AD_TOKEN=your-gateway-bearer-token-here
# Alternative: standard Azure key sent as the "api-key" header (leave blank if using AZURE_AD_TOKEN).
# AZURE_API_KEY=

# --- OpenAI (only if you have a personal key) ---
# LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# --- Google Gemini ---
GEMINI_API_KEY=your-gemini-key-here

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
